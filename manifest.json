{
  "manifest_version": 3,
  "name": "Selection TTS",
  "version": "0.1.0",
  "description": "Speak selected English, Japanese, Chinese, French, German, Spanish, Arabic, Russian, or Portuguese text via keyboard shortcut.",
  "permissions": ["activeTab"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Selection TTS",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "speak-selected-if-english": {
      "suggested_key": {
        "default": "Ctrl+X",
        "mac": "Command+I"
      },
      "description": "Detect selected text language and speak if it is English, Japanese, Chinese, French, German, Spanish, Arabic, Russian, or Portuguese"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": [
        "content/shared.js",
        "content/voiceProfiles.js",
        "content/speaker.js",
        "content/toast.js",
        "content/language/detect.js",
        "content/language/rules/fr.js",
        "content/language/rules/de.js",
        "content/language/rules/es.js",
        "content/language/rules/ar.js",
        "content/language/rules/ru.js",
        "content/language/rules/pt.js",
        "content/language/pickTargetLanguage.js",
        "content.js"
      ]
    }
  ]
}
